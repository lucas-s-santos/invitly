# ─────────────────────────────────────────────
# Invitly — variáveis de ambiente
# Copie para .env e preencha com seus valores.
# ─────────────────────────────────────────────

# Supabase (frontend usa apenas as VITE_*)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Service role: NUNCA exponha no frontend. Usar só em Edge Functions / backend.
SUPABASE_SERVICE_ROLE_KEY=

# Kiwify (pagamento) — usados no webhook/backend
KIWIFY_WEBHOOK_SECRET=
KIWIFY_PRODUCT_ID_BASIC=
KIWIFY_PRODUCT_ID_PREMIUM=
KIWIFY_PRODUCT_ID_PACK=

# Anthropic (sugestão de texto com IA) — backend/Edge Function
ANTHROPIC_API_KEY=

# App
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Invitly
